rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (required, 1-50 chars)
    //   - username: string (required, 3-20 chars, lowercase)
    //   - age: number (required, >= 18)
    //   - isVerified: bool (required)
    //   - createdAt: number (required)
    //   - bio: string (optional, < 200 chars)
    //   - photoURL: string (optional)
    //
    // Collection: posts
    // Document ID: postId
    // Fields:
    //   - authorId: string (required)
    //   - authorName: string (required)
    //   - authorPhoto: string (optional)
    //   - content: string (required, 1-1000 chars)
    //   - imageURL: string (optional)
    //   - likes: list (required, userIds)
    //   - commentsCount: number (required)
    //   - createdAt: number (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'username', 'age', 'isVerified', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 50 &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.age is number && data.age >= 18 &&
             data.isVerified is bool &&
             data.createdAt is number;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'content', 'likes', 'commentsCount', 'createdAt']) &&
             data.authorId is string &&
             data.authorName is string &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 1000 &&
             data.likes is list &&
             data.commentsCount is number &&
             data.createdAt is number;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.email == resource.data.email &&
                      request.resource.data.username == resource.data.username &&
                      request.resource.data.age == resource.data.age &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false; // Only admin can delete users
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        // Owner can update content
        (resource.data.authorId == request.auth.uid && isValidPost(request.resource.data)) ||
        // Anyone can like/unlike (only likes field changes)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }
  }
}
